# Jobmi - Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs

# ============================================
# NextAuth.js
# ============================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-here

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================
# France Travail API
# ============================================
# Pour obtenir vos credentials :
# 1. Créez un compte sur https://francetravail.io
# 2. Créez une application dans votre espace développeur
# 3. Souscrivez à l'API "Offres d'emploi v2"
# 4. Copiez vos Client ID et Client Secret
#
FRANCE_TRAVAIL_CLIENT_ID=your-france-travail-client-id
FRANCE_TRAVAIL_CLIENT_SECRET=your-france-travail-client-secret

# ============================================
# Backend API (Heroku)
# ============================================
# URL de l'API backend Jobmi
BACKEND_API_URL=https://lp-jobmi-ab6b9d72e9ba.herokuapp.com/api
